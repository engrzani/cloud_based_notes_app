rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Notes collection: users can only access their own notes
    match /notes/{noteId} {
      // Allow read only if the requesting user's UID matches the note's userId field
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // Allow create only if the user is authenticated and the note's userId matches their UID
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Allow update only if the user owns the note and cannot change the userId field
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;

      // Allow delete only if the user owns the note
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
